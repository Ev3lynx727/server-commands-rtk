{
  "name": "commands-rtk",
  "version": "0.4.0",
  "description": "MCP server with RTK caching for shell commands — TypeScript + ESM + Zod",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "commands-rtk": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "npx tsx suite-test.ts",
    "test:quick": "npx tsx suite-test.ts --quick",
    "verify": "npx tsc --noEmit && npm run build",
    "precommit": "npm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.4.0",
    "smol-toml": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist/",
    "rtk-hook.toml"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "shell",
    "command",
    "rtk",
    "token-minimization"
  ]
}
